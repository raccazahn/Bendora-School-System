# ============================================================================
# BENDORA SCHOOL SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env.local and fill in your values. NEVER commit secrets.
# ============================================================================

# 🌐 APP CONFIGURATION
APP_NAME=Bendora School System
APP_ENV=development               # development | staging | production
APP_URL=http://localhost:3000
SECRET_KEY=change-this-to-a-long-random-string
LOW_BANDWIDTH_MODE=true           # Optimizes assets & disables heavy animations

# 🗄️ DATABASE (PostgreSQL + Row-Level Security)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bendora_school
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false               # Set to true for dev debugging only

# ⚡ CACHING & SESSIONS (Redis)
REDIS_URL=redis://localhost:6379/0
SESSION_TIMEOUT_MINUTES=30

# 🔐 AUTHENTICATION (OIDC/OAuth2)
AUTH_PROVIDER=local               # local | auth0 | keycloak | google
AUTH_SECRET_KEY=your-jwt-secret-key
AUTH_TOKEN_EXPIRY_HOURS=12
ENABLE_MFA=false                  # Set to true for production

# 🏫 MULTI-TENANCY
TENANT_MODE=rls                   # rls (recommended) | schema | database
DEFAULT_TENANT_SLUG=bendora-demo
AUTO_PROVISION_NEW_TENANTS=false  # Set to true if allowing self-signup

# 📦 STORAGE (S3-Compatible for Assignments/Media)
STORAGE_PROVIDER=local            # local | aws-s3 | cloudflare-r2 | minio
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
STORAGE_BUCKET_NAME=bendora-school-assets
STORAGE_PUBLIC_URL=http://localhost:9000

# 📧 EMAIL & NOTIFICATIONS
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
FROM_EMAIL=noreply@bendora.tech
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_ALERTS=false           # Requires Twilio/Africa'sTalking integration

# 🔧 FEATURE FLAGS (Toggle per client via config later)
ENABLE_GRADEBOOK=true
ENABLE_ATTENDANCE=true
ENABLE_PARENT_PORTAL=true
ENABLE_OFFLINE_SYNC=true          # Critical for Liberia connectivity
ENABLE_BIOMETRIC_INTEGRATION=false

# 📊 MONITORING & LOGGING
SENTRY_DSN=
LOG_LEVEL=info                    # debug | info | warning | error
ENABLE_PERFORMANCE_METRICS=true

# 🇱🇷 LOCALIZATION & COMPLIANCE
DEFAULT_TIMEZONE=Africa/Monrovia
DEFAULT_CURRENCY=LRD
DATA_RETENTION_DAYS=730           # ~2 years (aligns with WAEC/Liberian MoE standards)
COMPLIANCE_MODE=liberia_moe       # Custom validation rules for Liberian curriculum
